# --- PostgreSQL ---
POSTGRES_USER=openbase
POSTGRES_PASSWORD=<generate-a-strong-password>
POSTGRES_DB=openbase
DATABASE_URL=postgres://openbase:<generate-a-strong-password>@db:5432/openbase

# --- Node ---
NODE_ENV=production

# --- SMTP (required for magic-link emails) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=<smtp-password>
SMTP_FROM=noreply@example.com

# --- Encryption (required in production) ---
# 32-byte hex key for AES-256-GCM encryption of data-source credentials at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPENBASE_ENCRYPTION_KEY=<64-char-hex-string>

# --- Shared link sessions (required in production) ---
# 32-byte hex key used to sign password-unlock sessions for protected shared links
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPENBASE_SHARE_LINK_SESSION_SECRET=<64-char-hex-string>

# --- Data directory for SQLite/DuckDB files (optional) ---
# OPENBASE_DATA_DIR=/data
